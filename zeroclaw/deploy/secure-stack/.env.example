# Copy this file to .env and update the secrets before running docker compose.
# Values are not consumed automatically; the configs under configs/* reference them
# as documentation so you remember what to fill in.
ZEROCLAW_API_KEY=http://host.docker.internal:11434
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.2
TLS_CERT_PATH=certs/dev-cert.pem
TLS_KEY_PATH=certs/dev-key.pem
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_ALLOWED_USERS=111111111
