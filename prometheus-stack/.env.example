# Copy to .env and fill values for testing
# TESLA OAuth2 Access Token (short-lived). For full flow implement PKCE.
TESLA_ACCESS_TOKEN=

# Poll interval in seconds
TESLA_POLL_INTERVAL=30

# Kafka bootstrap (optional for connectivity tests)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=tesla.telemetry

# Prometheus metrics port (optional)
PROMETHEUS_PORT=8000
