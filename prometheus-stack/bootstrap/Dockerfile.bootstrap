FROM python:3.11-slim

WORKDIR /bootstrap

COPY bootstrap/requirements-bootstrap.txt ./
RUN pip install --no-cache-dir -r requirements-bootstrap.txt

COPY bootstrap/pkce_bootstrap_with_registration.py ./pkce_bootstrap.py

# Create app directory for serving .well-known
RUN mkdir -p /app/.well-known/appspecific

ENTRYPOINT ["python", "pkce_bootstrap.py"]
