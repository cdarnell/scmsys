{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "2.52.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": "9.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": "9.0.0"
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": "9.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "-- Grafana --",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "justifyMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "(1 - avg(rate(windows_cpu_time_total{core=\"_Total\",mode=\"idle\"}[5m]))) * 100",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "title": "CPU Utilization (_Total)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "justifyMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "(1 - avg(windows_os_physical_memory_free_bytes) / avg(windows_cs_physical_memory_bytes)) * 100",
          "refId": "A"
        }
      ],
      "title": "Memory Utilization",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "justifyMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "(1 - avg(windows_logical_disk_free_bytes{volume=\"C:\"}) / avg(windows_logical_disk_size_bytes{volume=\"C:\"})) * 100",
          "refId": "A"
        }
      ],
      "title": "C: Drive Utilization",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "justifyMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "count(windows_service_status{status=\"running\"})",
          "refId": "A"
        }
      ],
      "title": "Running Services",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(windows_net_bytes_total{direction=\"received\",adapter!~\"isatap.*|Teredo.*\"}[5m]))",
          "legendFormat": "Receive",
          "refId": "A"
        },
        {
          "expr": "sum(rate(windows_net_bytes_total{direction=\"sent\",adapter!~\"isatap.*|Teredo.*\"}[5m]))",
          "legendFormat": "Send",
          "refId": "B"
        }
      ],
      "title": "Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "avg_over_time((1 - rate(windows_cpu_time_total{core=\"_Total\",mode=\"idle\"}[1m])) * 100[30m])",
          "legendFormat": "CPU Avg",
          "refId": "A"
        }
      ],
      "title": "CPU Trend",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 7,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "windows_service_status{service=~\"(zeroclaw|Docker|W32Time).*\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Key Service States",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "instance": false
            },
            "indexByName": {},
            "renameByName": {
              "status": "State"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "windows",
    "omen3090"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "OMEN 3090 Windows Overview",
  "uid": "windows-omen3090-overview",
  "version": 1
}
